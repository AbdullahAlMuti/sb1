{
  "manifest_version": 3,
  "name": "eBay Snipping Tool",
  "version": "1.3",
  "description": "Scrapes and watermarks Amazon and Walmart product data to streamline the eBay listing process.",
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "https://www.ebay.com/*",
    "*://amazon.com/*",
    "*://*.amazon.com/*",
    "*://amazon.co.uk/*",
    "*://*.amazon.co.uk/*",
    "*://amazon.de/*",
    "*://*.amazon.de/*",
    "*://amazon.ca/*",
    "*://*.amazon.ca/*",
    "*://amazon.com.au/*",
    "*://*.amazon.com.au/*",
    "*://www.walmart.com/*",
    "*://*.walmart.com/*",
    "*://www.walmart.ca/*",
    "*://*.walmart.ca/*",
    "https://gemini.google.com/*",
    "https://api.replicate.com/*",
    "https://cdn.jsdelivr.net/*",
    "https://script.google.com/*",
    "https://www.dailyfindz.com/*",
    "http://localhost:8080/*",
    "http://localhost:8081/*",
    "http://localhost:5173/*",
    "https://*.lovableproject.com/*",
    "https://*.lovable.app/*",
    "https://sellersuit.com/*",
    "https://*.sellersuit.com/*",
    "https://ojxzssooylmydystjvdo.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "eBay Snipping Tool",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "*://amazon.com/*",
        "*://*.amazon.com/*",
        "*://amazon.co.uk/*",
        "*://*.amazon.co.uk/*",
        "*://amazon.de/*",
        "*://*.amazon.de/*",
        "*://amazon.ca/*",
        "*://*.amazon.ca/*",
        "*://amazon.com.au/*",
        "*://*.amazon.com.au/*"
      ],
      "js": [
        "common/config.js",
        "common/performance.js",
        "common/storage.js",
        "common/ui.js",
        "common/analytics.js",
        "common/undo-manager.js",
        "common/editor-tools.js",
        "common/image-renderer.js",
        "common/amazon_image_extractor.js",
        "common/full_view_image_extractor.js",
        "content_scripts/amazon_injector.js",
        "content_scripts/image_editor.js",
        "content_scripts/amazon_fulfiller.js"
      ],
      "css": [
        "ui/panel.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://www.walmart.com/*",
        "*://www.walmart.ca/*"
      ],
      "js": [
        "common/config.js",
        "common/performance.js",
        "common/storage.js",
        "common/ui.js",
        "common/analytics.js",
        "common/undo-manager.js",
        "common/editor-tools.js",
        "common/image-renderer.js",
        "content_scripts/walmart_injector.js",
        "content_scripts/image_editor.js"
      ],
      "css": [
        "ui/panel.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://www.ebay.com/*/sell*",
        "*://www.ebay.com/sl/*",
        "*://www.ebay.com/lstng*"
      ],
      "js": [
        "common/config.js",
        "common/performance.js",
        "common/storage.js",
        "common/sync_utils.js",
        "common/ui.js",
        "common/analytics.js",
        "src/automation-clean.js",
        "src/image-uploader.js",
        "src/item-filler.js",
        "content_scripts/ebay_lister.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.ebay.com/sh/ord*",
        "https://www.ebay.com/mesh/ord*",
        "https://www.ebay.com/sh/reports*"
      ],
      "js": [
        "content_scripts/ebay_orders_sync_trigger.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.ebay.com/sh/ord/details*",
        "https://www.ebay.com/mesh/ord/details*"
      ],
      "js": [
        "common/config.js",
        "common/storage.js",
        "content_scripts/ebay_order_detail_scraper.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:8080/*",
        "http://localhost:8081/*",
        "http://127.0.0.1:8080/*",
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*",
        "https://*.lovableproject.com/*",
        "https://*.lovable.app/*",
        "https://sellersuit.com/*",
        "https://*.sellersuit.com/*"
      ],
      "js": [
        "content_scripts/auth_sync.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "common/config.js",
        "common/performance.js",
        "common/message-handler.js",
        "common/storage.js",
        "common/ui.js",
        "common/analytics.js",
        "common/undo-manager.js",
        "common/editor-tools.js",
        "common/image-renderer.js",
        "common/auth-helper.js",
        "ui/panel.html",
        "ui/editor-popup.html",
        "ui/editor_frame.html",
        "ui/editor-popup.css",
        "common/editor_core.js",
        "assets/watermark.png",
        "assets/stickers/*",
        "src/image-uploader.js",
        "src/item-filler.js",
        "content_scripts/description_paster.js"
      ],
      "matches": [
        "*://amazon.com/*",
        "*://*.amazon.com/*",
        "*://amazon.co.uk/*",
        "*://*.amazon.co.uk/*",
        "*://amazon.de/*",
        "*://*.amazon.de/*",
        "*://amazon.ca/*",
        "*://*.amazon.ca/*",
        "*://amazon.com.au/*",
        "*://*.amazon.com.au/*",
        "*://*.ebay.com/*",
        "*://*.walmart.com/*",
        "*://*.walmart.ca/*",
        "http://localhost:8080/*",
        "http://localhost:8081/*",
        "http://127.0.0.1:8080/*",
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*",
        "*://*.lovableproject.com/*",
        "*://*.lovable.app/*",
        "https://sellersuit.com/*",
        "https://*.sellersuit.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}