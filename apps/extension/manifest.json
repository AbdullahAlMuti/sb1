{
  "manifest_version": 3,
  "name": "SellerSuit",
  "version": "1.4.0",
  "description": "SellerSuit helps eBay sellers create listings faster by importing product data from supported marketplaces (Amazon, Walmart, AliExpress) and syncing their eBay orders for order management.",
  "homepage_url": "https://sellersuit.com",
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "alarms",
    "sidePanel",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://*.media-amazon.com/*",
    "https://*.ssl-images-amazon.com/*",
    "https://*.images-amazon.com/*",
    "https://*.walmartimages.com/*",
    "https://*.walmartimages.ca/*",
    "https://www.ebay.com/*",
    "https://msa-b1.ebay.com/*",
    "https://bulkedit.ebay.com/*",
    "https://amazon.com/*",
    "https://*.amazon.com/*",
    "https://amazon.co.uk/*",
    "https://*.amazon.co.uk/*",
    "https://amazon.de/*",
    "https://*.amazon.de/*",
    "https://amazon.ca/*",
    "https://*.amazon.ca/*",
    "https://amazon.com.au/*",
    "https://*.amazon.com.au/*",
    "https://www.walmart.com/*",
    "https://*.walmart.com/*",
    "https://www.walmart.ca/*",
    "https://*.walmart.ca/*",
    "https://script.google.com/*",
    "https://sellersuit.com/*",
    "https://*.sellersuit.com/*",
    "https://ojxzssooylmydystjvdo.supabase.co/*",
    "https://aliexpress.com/*",
    "https://*.aliexpress.com/*",
    "https://aliexpress.ru/*",
    "https://*.aliexpress.ru/*",
    "https://aliexpress.us/*",
    "https://*.aliexpress.us/*",
    "https://*.alicdn.com/*",
    "https://aliexpress.com/*",
    "https://*.aliexpress.com/*",
    "https://aliexpress.ru/*",
    "https://*.aliexpress.ru/*",
    "https://aliexpress.us/*",
    "https://*.aliexpress.us/*",
    "https://*.alicdn.com/*"
  ],
  "background": {
    "service_worker": "build/background.bundle.js"
  },
  "action": {
    "default_title": "SellerSuit"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://amazon.com/*",
        "https://*.amazon.com/*",
        "https://amazon.co.uk/*",
        "https://*.amazon.co.uk/*",
        "https://amazon.de/*",
        "https://*.amazon.de/*",
        "https://amazon.ca/*",
        "https://*.amazon.ca/*",
        "https://amazon.com.au/*",
        "https://*.amazon.com.au/*"
      ],
      "js": [
        "build/amazon.bundle.js"
      ],
      "css": [
        "ui/panel.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.walmart.com/*",
        "https://www.walmart.ca/*"
      ],
      "js": [
        "build/walmart.bundle.js"
      ],
      "css": [
        "ui/panel.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://aliexpress.com/*",
        "https://*.aliexpress.com/*",
        "https://aliexpress.ru/*",
        "https://*.aliexpress.ru/*",
        "https://aliexpress.us/*",
        "https://*.aliexpress.us/*"
      ],
      "js": [
        "build/aliexpress.bundle.js"
      ],
      "css": [
        "ui/panel.css",
        "ui/listing-card.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.ebay.com/*/sell*",
        "https://www.ebay.com/sl/*"
      ],
      "js": [
        "common/config.js",
        "common/storage.js",
        "common/pricing-engine.js",
        "common/sku-engine.js",
        "common/variation-normalizer.js",
        "common/retry-helper.js",
        "common/ebay-image-helper.js",
        "common/ebay-photo-uploader.js",
        "common/ebay-listing-api.js",
        "content_scripts/ebay_prelist.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://bulkedit.ebay.com/msku*"
      ],
      "js": [
        "common/config.js",
        "common/storage.js",
        "common/pricing-engine.js",
        "common/sku-engine.js",
        "common/variation-normalizer.js",
        "common/retry-helper.js",
        "common/ebay-image-helper.js",
        "common/ebay-photo-uploader.js",
        "common/ebay-listing-api.js",
        "content_scripts/ebay_bulkedit.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.ebay.com/lstng*"
      ],
      "js": [
        "common/config.js",
        "common/storage.js",
        "common/pricing-engine.js",
        "common/sku-engine.js",
        "common/images/core/image-schema.js",
        "common/images/core/image-cache.js",
        "common/ebay-image-helper.js",
        "common/images/upload/ebay-image-uploader.js",
        "src/image-uploader.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.ebay.com/lstng*",
        "https://www.ebay.co.uk/lstng*",
        "https://www.ebay.de/lstng*",
        "https://www.ebay.fr/lstng*",
        "https://www.ebay.com.au/lstng*",
        "https://www.ebay.it/lstng*",
        "https://www.ebay.es/lstng*"
      ],
      "js": [
        "content_scripts/ebay_draft_sku_guard.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.ebay.com/*",
        "https://*.ebay.co.uk/*",
        "https://*.ebay.de/*",
        "https://*.ebay.fr/*",
        "https://*.ebay.com.au/*",
        "https://*.ebay.it/*",
        "https://*.ebay.es/*"
      ],
      "js": [
        "common/listing-card-core.js",
        "content_scripts/ebay_item_scraper.js",
        "content_scripts/listing_card_injector.js"
      ],
      "css": [
        "ui/listing-card.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.ebay.com/sh/ord*",
        "https://www.ebay.com/mesh/ord*",
        "https://www.ebay.com/sh/reports*"
      ],
      "js": [
        "content_scripts/ebay_orders_sync_trigger.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.ebay.com/sh/ord/details*",
        "https://www.ebay.com/mesh/ord/details*"
      ],
      "js": [
        "common/config.js",
        "common/storage.js",
        "content_scripts/ebay_order_detail_scraper.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.ebay.com/sl/success*",
        "https://www.ebay.com/lstng/success*",
        "https://www.ebay.com/lstng*",
        "https://www.ebay.co.uk/sl/success*",
        "https://www.ebay.co.uk/lstng/success*",
        "https://www.ebay.co.uk/lstng*",
        "https://www.ebay.de/sl/success*",
        "https://www.ebay.de/lstng/success*",
        "https://www.ebay.de/lstng*",
        "https://www.ebay.fr/sl/success*",
        "https://www.ebay.fr/lstng/success*",
        "https://www.ebay.fr/lstng*",
        "https://www.ebay.com.au/sl/success*",
        "https://www.ebay.com.au/lstng/success*",
        "https://www.ebay.com.au/lstng*",
        "https://www.ebay.it/sl/success*",
        "https://www.ebay.it/lstng/success*",
        "https://www.ebay.it/lstng*",
        "https://www.ebay.es/sl/success*",
        "https://www.ebay.es/lstng/success*",
        "https://www.ebay.es/lstng*"
      ],
      "js": [
        "content_scripts/ebay_success.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://sellersuit.com/*",
        "https://*.sellersuit.com/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "js": [
        "content_scripts/bridge.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "ui/panel.html",
        "ui/panel.css",
        "ui/listing-card.css",
        "ui/editor-popup.html",
        "ui/editor_frame.html",
        "ui/editor-popup.css",
        "ui/product-details-popup.html",
        "ui/product-details-popup.css",
        "assets/logo.png",
        "assets/watermark.png",
        "assets/preparing.gif",
        "assets/stickers/*",
        "sidepanel/side-panel.html",
        "sidepanel/side-panel.css"
      ],
      "matches": [
        "https://amazon.com/*",
        "https://*.amazon.com/*",
        "https://amazon.co.uk/*",
        "https://*.amazon.co.uk/*",
        "https://amazon.de/*",
        "https://*.amazon.de/*",
        "https://amazon.ca/*",
        "https://*.amazon.ca/*",
        "https://amazon.com.au/*",
        "https://*.amazon.com.au/*",
        "https://*.ebay.com/*",
        "https://*.walmart.com/*",
        "https://*.walmart.ca/*",
        "https://sellersuit.com/*",
        "https://*.sellersuit.com/*",
        "https://aliexpress.com/*",
        "https://*.aliexpress.com/*",
        "https://aliexpress.ru/*",
        "https://*.aliexpress.ru/*",
        "https://aliexpress.us/*",
        "https://*.aliexpress.us/*",
        "https://aliexpress.com/*",
        "https://*.aliexpress.com/*",
        "https://aliexpress.ru/*",
        "https://*.aliexpress.ru/*",
        "https://aliexpress.us/*",
        "https://*.aliexpress.us/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self'"
  },
  "side_panel": {
    "default_path": "sidepanel/side-panel.html"
  }
}
