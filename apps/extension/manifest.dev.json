{
  "manifest_version": 3,
  "name": "SellerSuit",
  "version": "1.3.1",
  "description": "SellerSuit helps streamline eBay listing workflows by extracting product data from supported sites and preparing listing assets.",
  "homepage_url": "http://localhost:3001",
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "alarms",
    "sidePanel",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "*://*.media-amazon.com/*",
    "*://*.ssl-images-amazon.com/*",
    "*://*.images-amazon.com/*",
    "*://*.walmartimages.com/*",
    "*://*.walmartimages.ca/*",
    "https://www.ebay.com/*",
    "*://msa-b1.ebay.com/*",
    "*://bulkedit.ebay.com/*",
    "*://amazon.com/*",
    "*://*.amazon.com/*",
    "*://amazon.co.uk/*",
    "*://*.amazon.co.uk/*",
    "*://amazon.de/*",
    "*://*.amazon.de/*",
    "*://amazon.ca/*",
    "*://*.amazon.ca/*",
    "*://amazon.com.au/*",
    "*://*.amazon.com.au/*",
    "*://www.walmart.com/*",
    "*://*.walmart.com/*",
    "*://www.walmart.ca/*",
    "*://*.walmart.ca/*",
    "https://script.google.com/*",
    "https://sellersuit.com/*",
    "https://*.sellersuit.com/*",
    "https://ojxzssooylmydystjvdo.supabase.co/*",
    "*://aliexpress.com/*",
    "*://*.aliexpress.com/*",
    "*://aliexpress.ru/*",
    "*://*.aliexpress.ru/*",
    "*://aliexpress.us/*",
    "*://*.aliexpress.us/*",
    "*://*.alicdn.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://localhost:5173/*"
  ],
  "background": {
    "service_worker": "build/background.bundle.js"
  },
  "action": {
    "default_title": "SellerSuit"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "*://amazon.com/*",
        "*://*.amazon.com/*",
        "*://amazon.co.uk/*",
        "*://*.amazon.co.uk/*",
        "*://amazon.de/*",
        "*://*.amazon.de/*",
        "*://amazon.ca/*",
        "*://*.amazon.ca/*",
        "*://amazon.com.au/*",
        "*://*.amazon.com.au/*"
      ],
      "js": [
        "build/amazon.bundle.js"
      ],
      "css": [
        "ui/panel.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://www.walmart.com/*",
        "*://www.walmart.ca/*"
      ],
      "js": [
        "build/walmart.bundle.js"
      ],
      "css": [
        "ui/panel.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://aliexpress.com/*",
        "*://*.aliexpress.com/*",
        "*://aliexpress.ru/*",
        "*://*.aliexpress.ru/*",
        "*://aliexpress.us/*",
        "*://*.aliexpress.us/*"
      ],
      "js": [
        "build/aliexpress.bundle.js"
      ],
      "css": [
        "ui/panel.css",
        "ui/listing-card.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://www.ebay.com/*/sell*",
        "*://www.ebay.com/sl/*"
      ],
      "js": [
        "common/config.js",
        "common/storage.js",
        "common/pricing-engine.js",
        "common/sku-engine.js",
        "common/variation-normalizer.js",
        "common/retry-helper.js",
        "common/ebay-image-helper.js",
        "common/ebay-photo-uploader.js",
        "common/ebay-listing-api.js",
        "content_scripts/ebay_prelist.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://bulkedit.ebay.com/msku*"
      ],
      "js": [
        "common/config.js",
        "common/storage.js",
        "common/pricing-engine.js",
        "common/sku-engine.js",
        "common/variation-normalizer.js",
        "common/retry-helper.js",
        "common/ebay-image-helper.js",
        "common/ebay-photo-uploader.js",
        "common/ebay-listing-api.js",
        "content_scripts/ebay_bulkedit.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://www.ebay.com/lstng*"
      ],
      "js": [
        "common/config.js",
        "common/storage.js",
        "common/pricing-engine.js",
        "common/sku-engine.js",
        "common/images/core/image-schema.js",
        "common/images/core/image-cache.js",
        "common/ebay-image-helper.js",
        "common/images/upload/ebay-image-uploader.js",
        "src/image-uploader.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://www.ebay.com/lstng*",
        "*://www.ebay.co.uk/lstng*",
        "*://www.ebay.de/lstng*",
        "*://www.ebay.fr/lstng*",
        "*://www.ebay.com.au/lstng*",
        "*://www.ebay.it/lstng*",
        "*://www.ebay.es/lstng*"
      ],
      "js": [
        "content_scripts/ebay_draft_sku_guard.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.ebay.com/*",
        "*://*.ebay.co.uk/*",
        "*://*.ebay.de/*",
        "*://*.ebay.fr/*",
        "*://*.ebay.com.au/*",
        "*://*.ebay.it/*",
        "*://*.ebay.es/*"
      ],
      "js": [
        "common/listing-card-core.js",
        "content_scripts/ebay_item_scraper.js",
        "content_scripts/listing_card_injector.js"
      ],
      "css": [
        "ui/listing-card.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.ebay.com/sh/ord*",
        "https://www.ebay.com/mesh/ord*",
        "https://www.ebay.com/sh/reports*"
      ],
      "js": [
        "content_scripts/ebay_orders_sync_trigger.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.ebay.com/sh/ord/details*",
        "https://www.ebay.com/mesh/ord/details*"
      ],
      "js": [
        "common/config.js",
        "common/storage.js",
        "content_scripts/ebay_order_detail_scraper.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://www.ebay.com/sl/success*",
        "*://www.ebay.com/lstng/success*",
        "*://www.ebay.com/lstng*",
        "*://www.ebay.co.uk/sl/success*",
        "*://www.ebay.co.uk/lstng/success*",
        "*://www.ebay.co.uk/lstng*",
        "*://www.ebay.de/sl/success*",
        "*://www.ebay.de/lstng/success*",
        "*://www.ebay.de/lstng*",
        "*://www.ebay.fr/sl/success*",
        "*://www.ebay.fr/lstng/success*",
        "*://www.ebay.fr/lstng*",
        "*://www.ebay.com.au/sl/success*",
        "*://www.ebay.com.au/lstng/success*",
        "*://www.ebay.com.au/lstng*",
        "*://www.ebay.it/sl/success*",
        "*://www.ebay.it/lstng/success*",
        "*://www.ebay.it/lstng*",
        "*://www.ebay.es/sl/success*",
        "*://www.ebay.es/lstng/success*",
        "*://www.ebay.es/lstng*"
      ],
      "js": [
        "content_scripts/ebay_success.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://sellersuit.com/*",
        "https://*.sellersuit.com/*",
        "http://localhost/*",
        "http://localhost:5173/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "js": [
        "content_scripts/bridge.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "common/config.js",
        "common/html-sanitizer.js",
        "common/listing-draft.js",
        "common/variation-normalizer.js",
        "common/constants.js",
        "common/performance.js",
        "common/message-handler.js",
        "common/storage.js",
        "common/ui.js",
        "common/analytics.js",
        "common/undo-manager.js",
        "common/editor-tools.js",
        "common/image-renderer.js",
        "common/auth-helper.js",
        "common/ebay-photo-uploader.js",
        "common/pricing-engine.js",
        "common/sku-engine.js",
        "common/ebay-listing-api.js",
        "common/retry-helper.js",
        "common/api-client.js",
        "common/sync-utils.js",
        "ui/panel.html",
        "ui/panel.css",
        "ui/listing-card.css",
        "ui/editor-popup.html",
        "ui/editor_frame.html",
        "ui/editor-popup.css",
        "ui/calculator.js",
        "common/editor_core.js",
        "assets/logo.png",
        "assets/watermark.png",
        "assets/stickers/*",
        "src/image-uploader.js",
        "common/images/core/image-schema.js",
        "common/images/core/image-normalizer.js",
        "common/images/core/image-deduper.js",
        "common/images/core/image-validator.js",
        "common/images/core/image-cache.js",
        "common/images/core/extraction-engine.js",
        "common/images/adapters/amazon.image-adapter.js",
        "common/images/adapters/walmart.image-adapter.js",
        "common/images/fallback/modal-click-extractor.js",
        "common/images/upload/ebay-image-uploader.js",
        "content_scripts/description_paster.js",
        "content_scripts/bridge.js",
        "sidepanel/side-panel.html",
        "sidepanel/side-panel.css",
        "sidepanel/panel-store.js",
        "sidepanel/panel-main.js"
      ],
      "matches": [
        "*://amazon.com/*",
        "*://*.amazon.com/*",
        "*://amazon.co.uk/*",
        "*://*.amazon.co.uk/*",
        "*://amazon.de/*",
        "*://*.amazon.de/*",
        "*://amazon.ca/*",
        "*://*.amazon.ca/*",
        "*://amazon.com.au/*",
        "*://*.amazon.com.au/*",
        "*://*.ebay.com/*",
        "*://*.walmart.com/*",
        "*://*.walmart.ca/*",
        "https://sellersuit.com/*",
        "https://*.sellersuit.com/*",
        "*://aliexpress.com/*",
        "*://*.aliexpress.com/*",
        "*://aliexpress.ru/*",
        "*://*.aliexpress.ru/*",
        "*://aliexpress.us/*",
        "*://*.aliexpress.us/*",
        "http://localhost/*",
        "http://localhost:5173/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
