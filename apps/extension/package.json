{
  "name": "@sellersuit/extension",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "test": "node --test \"tests/**/*.test.js\"",
    "test:watch": "node --test --watch \"tests/**/*.test.js\"",
    "build": "vite build && vite build -c vite.config.amazon.js && vite build -c vite.config.walmart.js",
    "typecheck": "tsc -p jsconfig.json",
    "lint": "eslint \"**/*.js\"",
    "lint:fix": "eslint --fix \"**/*.js\"",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\"",
    "prepare:dev": "npm run build && node scripts/prepare-extension-dev.js",
    "prepare:prod": "npm run build && node scripts/prepare-extension-prod.js",
    "verify:prod": "node scripts/verify-extension-prod.js"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "dompurify": "^3.4.11"
  }
}
