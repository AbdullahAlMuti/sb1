{
  "name": "@sellersuit/extension",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/watch.js",
    "test": "node --test \"tests/**/*.test.js\"",
    "test:watch": "node --test --watch \"tests/**/*.test.js\"",
    "build": "npm run sync:aliexpress-manifests && node scripts/sync-pricing-core.js && vite build && vite build --config vite.config.amazon.js && vite build --config vite.config.walmart.js && vite build --config vite.config.aliexpress.js && vite build --config vite.config.background.js",
    "build:suppliers": "vite build",
    "build:background": "vite build --config vite.config.background.js",
    "build:amazon": "vite build --config vite.config.amazon.js",
    "build:walmart": "vite build --config vite.config.walmart.js",
    "build:aliexpress": "vite build --config vite.config.aliexpress.js",
    "discover:aliexpress": "node scripts/discover-aliexpress-domains.mjs",
    "sync:aliexpress-manifests": "node scripts/sync-aliexpress-manifests.mjs",
    "check:aliexpress-manifests": "node scripts/sync-aliexpress-manifests.mjs --check",
    "typecheck": "tsc -p jsconfig.json",
    "lint": "eslint \"tests/**/*.js\" \"suppliers/**/*.js\"",
    "lint:fix": "eslint --fix \"tests/**/*.js\" \"suppliers/**/*.js\"",
    "format": "prettier --write \"tests/**/*.js\" \"suppliers/**/*.js\"",
    "format:check": "prettier --check \"tests/**/*.js\" \"suppliers/**/*.js\"",
    "prepare:dev": "npm run build && node scripts/prepare-extension-dev.js && node scripts/verify-extension-dev.js",
    "prepare:prod": "npm run build && node scripts/prepare-extension-prod.js",
    "verify:dev": "node scripts/verify-extension-dev.js",
    "verify:prod": "node scripts/verify-extension-prod.js"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "vite": "^8.0.16"
  }
}
