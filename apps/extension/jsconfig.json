{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "checkJs": true,
    "noEmit": true,
    "lib": ["es2022", "dom"],
    "types": [],
    "maxNodeModuleJsDepth": 0,
    "skipLibCheck": true
  },
  "include": ["suppliers/**/*.js", "suppliers/global.d.ts"],
  "exclude": [
    "node_modules",
    "../../node_modules",
    "build",
    "dist"
  ]
}
