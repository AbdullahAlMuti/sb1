# Local development only.
# Copy this file to .env.local for localhost development.
#
# Do not use the production Supabase project locally.
# Do not use live Stripe/payment keys locally.
# Use local Supabase values or another non-production test project.

VITE_SUPABASE_PROJECT_ID=local-project-id
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=local-publishable-key
VITE_TURNSTILE_SITE_KEY=local-turnstile-site-key
VITE_APP_URL=http://localhost:3001
VITE_ADMIN_URL=http://localhost:3002
VITE_MARKETING_URL=http://localhost:3000

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=local-anon-key
SUPABASE_SERVICE_ROLE_KEY=local-service-role-key

RESEND_API_KEY=test-resend-key
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_test_placeholder
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
LOVABLE_API_KEY=test-lovable-key
OPENAI_API_KEY=test-openai-key
ENVIRONMENT=development

APP_URL=http://localhost:3001
PUBLIC_APP_URL=http://localhost:3001
MARKETING_APP_URL=http://localhost:3000
ADMIN_APP_URL=http://localhost:3002
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
EXTENSION_ALLOWED_ORIGINS=http://localhost:3001
INTERNAL_FUNCTION_SECRET=local-internal-secret
